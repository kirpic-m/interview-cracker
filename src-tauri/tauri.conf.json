{
  "productName": "Interview Cracker",
  "version": "0.2.0",
  "identifier": "com.interviewcracker.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Interview Cracker",
        "width": 950,
        "height": 750,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "minWidth": 700,
        "minHeight": 550,
        "visible": true
      },
      {
        "label": "overlay",
        "title": "",
        "width": 320,
        "height": 200,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "transparent": true,
        "shadow": false,
        "x": 100,
        "y": 100,
        "acceptFirstMouse": true,
        "focus": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all"
  }
}
